# Dockerfile for a Python application
FROM python:3.11-slim

# Install Java 11
RUN apt-get update && apt-get install -y openjdk-11-jdk
ENV JAVA_HOME=/usr/lib/jvm/java-11-openjdk-amd64

# download  & install pipenv
RUN pip install --no-cache-dir --upgrade pip && pip install --no-cache-dir pipenv

# working directory
WORKDIR /src

# copy Pipfile and Pipfile.lock
COPY Pipfile Pipfile.lock .

# install dependencies
RUN pipenv install --deploy --ignore-pipfile

# copy the rest of the application code
COPY ./src .

# command to run the application
CMD ["pipenv", "run", "bash", "-c", "python scripts/scraping.py && python scripts/data_processing_spark.py"]