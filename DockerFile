FROM python:3.11-slim

# Install Java & Nettoyage
RUN apt-get update && apt-get install -y default-jdk curl && apt-get clean

ENV JAVA_HOME=/usr/lib/jvm/default-java
ENV PATH=$JAVA_HOME/bin:$PATH

# Pipenv & Pyspark
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir pipenv pyspark delta-spark

# Pre-download des packages Delta pour gagner du temps au runtime
RUN python3 -c "from pyspark.sql import SparkSession; from delta import configure_spark_with_delta_pip; builder = SparkSession.builder.appName('warmup'); configure_spark_with_delta_pip(builder).getOrCreate()"

WORKDIR /src
COPY Pipfile Pipfile.lock ./
RUN pipenv install --deploy --ignore-pipfile --python /usr/local/bin/python3.11

COPY ./src .

CMD ["pipenv", "run", "bash", "-c", "python scripts/scraping.py && python scripts/data_processing_spark.py && python scripts/real_estate_ml.py"]